# Supabase Configuration
# Copy this file to .env and fill in your values

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=your-supabase-secret-key

# Vehicle Configuration
# Unique identifier for this vehicle (e.g., VIN, license plate, or custom ID)
VEHICLE_ID=VEHICLE-001
VEHICLE_NAME=My Vehicle

# YOLO Detection (Phone/Drinking detection)
# Set to 'false' to disable YOLO model (useful for Raspberry Pi or systems without GPU)
# Accepted values: true, false, 1, 0, yes, no
ENABLE_YOLO=true

# Video stream flags
ENABLE_STREAM=true     # Enable the stream
STREAM_QUALITY=67      # JPEG quality (0-100)
STREAM_FPS=25           # Target upload rate
STREAM_WIDTH=640       # Downscale width in px

# Shazam Music Recognition
# Enable ambient music detection and identification
# Accepted values: true, false, 1, 0, yes, no
ENABLE_SHAZAM=true
SHAZAM_INTERVAL=20     # Seconds between recognition attempts (default: 20)
SHAZAM_DEBUG=false     # Save audio samples to audio_samples/ folder for debugging

# Dashcam Recording
# Records annotated camera frames to recordings/{trip_id}.mp4
ENABLE_DASHCAM=true

YOLO_MODEL_PATH=yolo-models/yolo26n.pt

MIRROR_CAMERA=false
